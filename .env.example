# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
# Local development: docker-compose provides a Postgres instance at this URL.
DATABASE_URL=postgres://casanomina:casanomina_dev@localhost:5432/casanomina

# ── API server ────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info           # debug | info | warn | error
NODE_ENV=development

# Comma-separated list of origins allowed to call the API.
# In local dev, leave commented (all origins allowed).
# ALLOWED_ORIGINS=https://your-frontend.example.com

# ── Auth (choose one) ─────────────────────────────────────────────────────────
# Clerk (https://clerk.com — free tier available)
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# NextAuth (if you prefer open-source auth)
# NEXTAUTH_SECRET=a-long-random-string
# NEXTAUTH_URL=http://localhost:5173

# ── Transactional email (Resend) ────────────────────────────────────────────
# Optional. When unset, emailService.ts logs invite emails instead of sending
# them — safe default for local dev and tests. Get a free key at resend.com.
# RESEND_API_KEY=re_...

# "From" address used for outgoing emails. Must be a verified sender/domain
# in your Resend account (or use the resend.dev sandbox address below).
# EMAIL_FROM=onboarding@resend.dev
